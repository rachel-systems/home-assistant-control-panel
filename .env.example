# Set DEMO_MODE=true to run the app with sample data only.
DEMO_MODE=true
DEMO_DATA_FILE=demo_data.json

# When DEMO_MODE=false, provide your Home Assistant instance details below.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# App settings
HOST=127.0.0.1
PORT=5000
DEBUG=false

# UI filtering
DEFAULT_DOMAINS=light,switch,sensor,binary_sensor,climate,fan,cover,media_player,lock,vacuum,camera
SHOW_UNAVAILABLE=false
